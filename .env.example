# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Create an API key at https://platform.openai.com/api-keys
# Place your real key in .env.local (never commit it)
OPENAI_API_KEY=sk-placeholder
OPENAI_MODEL=gpt-4o
# Voice features (speech-to-text and text-to-speech)
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=coral

# ─── Encryption ───────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SUBMISSION_ENCRYPTION_KEY=your-64-char-hex-key-here

# ─── WhatsApp (Meta Cloud API) ────────────────────────────────────────────────
# Optional — app works without these; falls back to click-to-chat links
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_API_VERSION=v21.0

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Optional — get an API key at https://resend.com
RESEND_API_KEY=re_placeholder
EMAIL_FROM=noreply@yourdomain.com

# ─── Cron / Internal ──────────────────────────────────────────────────────────
# A random secret used to protect the analysis trigger endpoint
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=your-cron-secret-here

# ─── Session ──────────────────────────────────────────────────────────────────
# A random secret for signing JWT session tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SESSION_SECRET=your-session-secret-here

# ─── Demo Mode ────────────────────────────────────────────────────────────────
# Set to "true" to enable demo mode (no external credentials required)
DEMO_MODE=false
